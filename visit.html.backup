<!DOCTYPE html>
<html lang="gu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Visit Us | AIT & Financial Solutions</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        :root { 
            --bg-dark: #060a13; 
            --ait-dark-blue: #09377a; 
            --ait-red: #ff2a2a;      
            --ait-cyan: #4df0ff;     
            --text-white: #ffffff;
            --card-bg: #0d131f; 
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Poppins', sans-serif; 
            background-color: var(--bg-dark); 
            color: var(--text-white);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
        }

        .container {
            max-width: 800px;
            width: 100%;
            text-align: center;
        }

        .header {
            margin-bottom: 30px;
            padding: 20px;
        }

        .logo-box img {
            height: 100px;
            border-radius: 15px;
            margin-bottom: 15px;
            box-shadow: 0 0 20px rgba(77, 240, 255, 0.2);
        }

        h1 { font-family: 'Orbitron'; color: var(--ait-cyan); font-size: 1.8rem; margin-bottom: 10px; }
        
        /* --- Address Section --- */
        .info-card {
            background: var(--card-bg);
            border: 2px solid var(--ait-dark-blue);
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 25px;
            text-align: left;
            position: relative;
            overflow: hidden;
        }

        .info-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 5px; height: 100%;
            background: var(--ait-red);
        }

        .address-title { color: var(--ait-red); font-family: 'Orbitron'; font-size: 1.2rem; margin-bottom: 15px; }
        .address-text { font-size: 1.1rem; line-height: 1.6; margin-bottom: 20px; color: #ccc; }

        /* --- Map Section --- */
        .map-container {
            width: 100%;
            height: 350px;
            border-radius: 15px;
            overflow: hidden;
            border: 2px solid var(--ait-cyan);
            margin-bottom: 25px;
        }

        /* --- Services Grid --- */
        .services-summary {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 30px;
        }

        .service-mini-card {
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 10px;
            border: 1px solid var(--ait-dark-blue);
            text-align: center;
        }

        .service-mini-card i { font-size: 1.5rem; color: var(--ait-cyan); margin-bottom: 10px; }
        .service-mini-card h4 { font-family: 'Orbitron'; font-size: 0.9rem; color: #fff; }

        /* --- Buttons --- */
        .btn-group { display: flex; flex-direction: column; gap: 15px; }
        .btn {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 15px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: bold;
            font-family: 'Orbitron';
            transition: 0.3s;
        }
        .btn-map { background: var(--ait-cyan); color: #000; }
        .btn-wa { background: #25d366; color: #fff; }
        .btn:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.3); }

        @media (max-width: 600px) {
            .services-summary { grid-template-columns: 1fr; }
            h1 { font-size: 1.5rem; }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <div class="logo-box">
            <img src="logo.png" alt="AIT Logo">
        </div>
        <h1>Contact & Location</h1>
        <p style="color: #888;">Dominating the Digital Frontier</p>
    </div>

    <div class="info-card">
        <h3 class="address-title"><i class="fas fa-map-marker-alt"></i> OUR HUB ADDRESS</h3>
        <p class="address-text">
            Plot No. 90, 2nd Floor, Arav Complex,<br>
            Opp. Rammantra Mandir,<br>
            Bhavnagar, Gujarat - 364001
        </p>
        <p style="font-size: 1.2rem; font-weight: bold; color: var(--ait-cyan);">
            <i class="fas fa-phone-alt"></i> +91 93277 36999
        </p>
    </div>

    <div class="services-summary">
        <div class="service-mini-card">
            <i class="fas fa-user-graduate"></i>
            <h4>IT Education & Training</h4>
            <p style="font-size: 0.8rem; color: #888;">Hacking, Networking, Cloud</p>
        </div>
        <div class="service-mini-card">
            <i class="fas fa-tools"></i>
            <h4>Technical Solutions</h4>
            <p style="font-size: 0.8rem; color: #888;">Repairing & Data Recovery</p>
        </div>
        <div class="service-mini-card" style="grid-column: span 2; border-color: #fbbf24;">
            <i class="fas fa-chart-line" style="color: #fbbf24;"></i>
            <h4 style="color: #fbbf24;">Financial & Life Insurance Advisor</h4>
            <p style="font-size: 0.8rem; color: #888;">TATA AIA Financial Planning</p>
        </div>
    </div>

    <div class="map-container">
        <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3705.5123456789!2d72.14!3d21.76!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjHCsDQ1JzM2LjAiTiA3MsKwMDgnMjQuMCJF!5e0!3m2!1sen!2sin!4v1234567890" 
            width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy">
        </iframe>
    </div>

    <div class="btn-group">
        <a href="https://maps.google.com/?q=Arav+Complex+Bhavnagar" class="btn btn-map">
            <i class="fas fa-directions" style="margin-right: 10px;"></i> OPEN IN GOOGLE MAPS
        </a>
        <a href="https://wa.me/919327736999" class="btn btn-wa">
            <i class="fab fa-whatsapp" style="margin-right: 10px; font-size: 1.3rem;"></i> CHAT ON WHATSAPP
        </a>
        <a href="index.html" style="color: var(--ait-cyan); text-decoration: none; margin-top: 10px; font-size: 0.9rem;">
            <i class="fas fa-arrow-left"></i> Back to Website
        </a>
    </div>

    <footer style="margin-top: 50px; padding-bottom: 20px; font-size: 0.8rem; color: #555;">
        © 2026 Advanced Information Technology (AIT)
    </footer>
</div>

</body>
</html>